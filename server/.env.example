# Copy to .env and fill in SMTP values to enable real email sending
# Example: AWS SES SMTP relay (create SMTP credentials in SES and use the endpoint for your region)
# Obtain SMTP credentials in SES (SMTP username/password) or use IAM-based sending.
# Example SES settings (us-east-1):
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=YOUR_SES_SMTP_USERNAME
SMTP_PASS=YOUR_SES_SMTP_PASSWORD
SMTP_FROM=verified-sender@example.com
AWS_REGION=add-region
AWS_ACCESS_KEY_ID=access-key-id
AWS_SECRET_ACCESS_KEY=secret-access-key

# Where submissions are sent (default: chido.ukaigwe@sbmediagroup.com)
TO_EMAIL=chido.ukaigwe@sbmediagroup.com

# Server port (optional)
PORT=3001

# Notes:
# - Ensure the `SMTP_FROM` address is verified in SES (or that your account is out of the sandbox).
# - If using AWS IAM or SDK-based sending, configure accordingly and modify `server/index.js` to use SES SDK.

# Optional: enable AWS SDK SES path (preferred). When `USE_AWS_SDK=true` the server will attempt to use
# credentials from `server/aws-credentials.json` or from `AWS_ACCESS_KEY_ID`/`AWS_SECRET_ACCESS_KEY` env vars.
USE_AWS_SDK=true
AWS_REGION=us-east-1
